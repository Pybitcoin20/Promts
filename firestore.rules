rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() { return request.auth != null; }
    function isOwner(userId) { return isSignedIn() && request.auth.uid == userId; }
    function isVerified() { return isSignedIn() && request.auth.token.email_verified == true; }
    
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    
    function isValidId(id) { 
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); 
    }

    // --- Entity Validations ---
    
    function isValidUser(data) {
      return data.keys().hasAll(['username', 'email', 'createdAt']) &&
             data.keys().size() <= 5 &&
             data.username is string && data.username.size() <= 50 &&
             data.email is string && data.email.size() <= 100 &&
             data.createdAt == request.time;
    }

    function isValidPrompt(data) {
      return data.keys().hasAll(['title', 'content', 'authorId', 'authorName', 'likesCount', 'createdAt']) &&
             data.keys().size() <= 7 &&
             data.title is string && data.title.size() <= 100 &&
             data.content is string && data.content.size() <= 5000 &&
             data.authorId == request.auth.uid &&
             data.likesCount is number &&
             data.createdAt == request.time;
    }

    function isValidLike(data) {
      return data.keys().hasAll(['userId', 'promptId', 'createdAt']) &&
             data.userId == request.auth.uid &&
             isValidId(data.promptId) &&
             data.createdAt == request.time;
    }

    // --- Rules ---

    match /users/{userId} {
      allow get: if isSignedIn();
      allow list: if false; // Blanket user list forbidden
      allow create: if isOwner(userId) && isValidUser(incoming());
      allow update: if isOwner(userId) && 
                      isValidUser(incoming()) && 
                      incoming().createdAt == existing().createdAt &&
                      incoming().email == existing().email &&
                      incoming().diff(existing()).affectedKeys().hasOnly(['username', 'avatarUrl', 'bio']);
    }

    match /prompts/{promptId} {
      allow get: if true;
      allow list: if true; // Public marketplace
      allow create: if isVerified() && isValidPrompt(incoming());
      allow update: if (isOwner(existing().authorId) && 
                        isValidPrompt(incoming()) &&
                        incoming().authorId == existing().authorId &&
                        incoming().createdAt == existing().createdAt &&
                        incoming().diff(existing()).affectedKeys().hasOnly(['title', 'content', 'imageUrl', 'likesCount', 'type'])) ||
                      (isSignedIn() && 
                        incoming().diff(existing()).affectedKeys().hasOnly(['likesCount']) &&
                        (incoming().likesCount == existing().likesCount + 1 || incoming().likesCount == existing().likesCount - 1));
      allow delete: if isOwner(existing().authorId);
    }

    match /likes/{likeId} {
      allow get: if isSignedIn();
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isVerified() && isValidLike(incoming()) && likeId == request.auth.uid + '_' + incoming().promptId;
      allow delete: if isOwner(existing().userId);
    }

    match /saved_prompts/{saveId} {
      allow get, delete: if isOwner(existing().userId);
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isVerified() && 
                      incoming().userId == request.auth.uid && 
                      saveId == request.auth.uid + '_' + incoming().promptId &&
                      incoming().createdAt == request.time;
    }
    
    match /collections/{collectionId} {
      allow get: if true;
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isVerified() && 
                      incoming().userId == request.auth.uid &&
                      incoming().createdAt == request.time;
      allow update: if isOwner(existing().userId) && 
                      incoming().userId == existing().userId &&
                      incoming().diff(existing()).affectedKeys().hasOnly(['title', 'promptIds']);
      allow delete: if isOwner(existing().userId);
    }
  }
}
